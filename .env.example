# 幣安 API（只開合約交易，絕對不開提幣）
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here

# 環境設定（true = Testnet，false = 真實交易）
BINANCE_TESTNET=true

# === 風控參數 ===
MAX_LEVERAGE=3
MARGIN_USDT=10            # 每筆固定保證金（USDT）
MAX_POSITIONS=10          # 同時最多開幾個倉
RISK_PCT_PER_TRADE=0.10   # 每筆最多虧損 = MARGIN × 10%
MAX_DAILY_LOSS=0.08       # 每日最大虧損 8%
MAX_SAME_DIR_HIGH_CORR=2  # 同方向高相關倉位上限
HIGH_CORR_THRESHOLD=0.8

# === 排程設定 ===
RESCAN_MIN=15             # 每幾分鐘重新選幣
SIGNAL_CHECK_MIN=5        # 每幾分鐘檢查訊號（WS 事件驅動為主，此為兜底）
SYNC_SEC=30               # 每幾秒同步倉位狀態

# === 策略選擇 ===
# 可選：naked_k_fib / mean_reversion / breakdown_short / momentum_long /
#       smc_sweep / ma_sr_breakout / ma_sr_short / all
# 也支援逗號分隔列表
# 2026-04-30 P3A 後收斂為 MASR Long-only
# 原因：cross-strategy stability audit 顯示 NKF/SMC/BD 都 REJECTED，
# 只有 MASR 在 wf segment 下穩定（wr_std 4.7pp、min_n 222、total +124U/39m）。
# 見 reports/p3a_cross_strategy_stability_*.md。其他策略 code/env 全保留。
ACTIVE_STRATEGY=ma_sr_breakout

# === 共通策略參數 ===
COOLDOWN_BARS=3
MIN_SIGNAL_SCORE=2        # NKF 最低訊號強度（1-5）

# === Regime Gate 控制（v5）===
# 回測證據：regime gate ON 時 BD/ML 從正轉負（總損失 -25 USDT），
# BD 在 TREND_DOWN 易被 short squeeze 洗、ML 在 TREND_UP 變追高。
# 關掉讓策略自由發揮（NKF 不受影響）。
REGIME_GATE_ENABLED=false

# === 選幣（coin_screener）===
SCREEN_MIN_SCORE=6
SCREEN_MIN_VOL_M=5
SCREEN_ADX_MIN=15
SCREEN_ADX_MAX=55
SCREEN_ATR_MAX_LONG=6.0
SCREEN_ATR_MAX_SHORT=12.0

# === 入場參數（NKF 用）===
# 0.015：fib 反轉常有 wick 過頭，寬容忍度才能抓彈。試過 0.012
# 反而把 TP 命中率從 27% 砍到 23%。維持 0.015。
SIGNAL_FIB_TOL=0.015
SIGNAL_VOL_RATIO=1.0
SIGNAL_VOL_RISING=false
SIGNAL_FIB_MAX_TOUCHES=3
SIGNAL_FRACTAL_LR=3

# === NKF 策略參數 ===
NKF_TIMEFRAME=15m
NKF_MIN_RR=1.2

# === ML（Momentum Long）參數 ===
# 回測：38.4% win，提高 MIN_SCORE 過濾低品質突破
ML_MIN_SCORE=5
# v2 補強：Volume Burst 替代路徑 + HTF EMA50 confluence
# ML v2 經 12m 回測驗證失敗（v1 +7.70 → v2 +5.19）：HTF 過濾把部分
# 好交易擋掉。預設全關，ML 維持 v1 純突破邏輯。
ML_V2_ENABLED=false
ML_V2_VOL_BURST_ENABLED=false
ML_V2_VOL_BURST_MULT=3.0
ML_V2_VOL_BURST_CLOSE_PCT=0.7
ML_V2_HTF_ENABLED=false
ML_V2_HTF_TIMEFRAME=4h
ML_V2_HTF_EMA_PERIOD=50
ML_V2_HTF_MIN_SLOPE_PCT=0.001
ML_V2_HTF_SLOPE_BARS=5

# === MASR（MA + S/R Breakout）策略（v6 新增）===
# 多頭趨勢中突破近 100 根 4h 至少 2 次測試的水平阻力時做多
MASR_TIMEFRAME=4h
MASR_SCREEN_VOL_M=50.0
MASR_SCREEN_ATR_MIN_PCT=2.0
MASR_SCREEN_ATR_MAX_PCT=8.0
MASR_SCREEN_EMA200_MAX_PCT=0.50
MASR_TOP_N=10
MASR_MIN_30D_RETURN_PCT=0.0
MASR_MIN_LISTING_DAYS=180
# P4 sweep 後保守版 (stability-adjusted #1)
# 證據：reports/p4_masr_sweep_20260430_1740.md
# audit_masr_top3_*.md：三段全正 / wr_std 2.4pp / min_n_trades 267 → ROBUST
# 變更項目：LOOKBACK 100→50、TOL 0.3→0.2、TP1_RR 2.0→1.5、SL_ATR 1.5→2.0
MASR_RES_LOOKBACK=50
MASR_RES_TOL_ATR_MULT=0.2
MASR_RES_MIN_TOUCHES=2
MASR_VOL_MULT=1.3
# 最小突破幅度：經 12m 回測驗證，砍掉的訊號是正期望，filter 砍錯方向
# 預設 0（關閉）。code 路徑保留供未來嘗試其他 PCT
MASR_MIN_BREAKOUT_PCT=0.0
MASR_ATR_PERCENTILE_MAX=0.80
MASR_MAX_DIST_FROM_EMA50=0.08
MASR_SL_ATR_MULT=2.0
MASR_TP1_RR=1.5
MASR_TP2_RR=4.0
# TP1 後 SL 移到 entry（保本）：剩餘 50% 至少不虧
MASR_BE_AFTER_TP1=true
MASR_MIN_SCORE=2
MASR_TIMEOUT_BARS=18
MASR_MIN_RR=1.5

# === MASR Short（MA + S/R Breakdown SHORT，P12C 後保守版）===
# 證據：reports/p12c_masr_short_sweep_20260430_2305.md
# fast.top3 ROBUST：三段全正 / wr_std 2.2pp（codebase 全部 audit 中最低）/
#                   min_n_trades 264 / stability-adjusted PnL +124.23U
# variant=fast 顯著優於 slow（adj +124.23 vs +83.58；wr_std 2.2pp vs 4.7pp；
#                            min_n 264 vs 203）
#
# v1 規格（已封存於 strategies/ma_sr_short.py:MaSrShortV1Deprecated）：
#   過嚴 mandatory filter，39m 只 3 trades。code 保留供 archeology。
# v2 (此區 active config) 從 backtest.run_backtest_masr_short_v2 移植到 live；
# P12B 等價驗證 6/6 PASS（BTC/ETH/SOL × 12m × slow+fast variants，
# 0 real_mismatches）。
#
# 1H timeframe（vs Long 4H）；24h 強制平倉。
MASR_SHORT_TIMEFRAME=1h
# BTC 大盤過濾（v1 用，v2 改用 V2_* 分級 BTC regime gate）
MASR_SHORT_BTC_HTF_TIMEFRAME=4h
MASR_SHORT_BTC_FAST_EMA=50
MASR_SHORT_BTC_SLOW_EMA=200
MASR_SHORT_BTC_MAX_24H_PCT=0.02
# 選幣（每次 scan 用日線判斷；v2 用 V2_VOL_M / V2_7D_MAX_RETURN / V2_DIST_HIGH_PCT）
MASR_SHORT_SCREEN_VOL_M=50.0
MASR_SHORT_SCREEN_7D_DROP_PCT=0.05
MASR_SHORT_SCREEN_DIST_HIGH_PCT=0.15
MASR_SHORT_TOP_N=10
MASR_SHORT_MIN_LISTING_DAYS=180
# 排除避險資產 — 逗號分隔（與 cfd asset_class filter 重疊；feature_filter
# 已 cover 所以這個可清空，但保留向後相容）
MASR_SHORT_EXCLUDED_SYMBOLS=PAXGUSDT,XAUUSDT

# ── 進場條件（1H K 線）── P12C sweep 後保守版 ──
# 試過 100 (sweep 過程 baseline) → 150 stability 顯著好；fast 變體用更長 lookback
MASR_SHORT_RES_LOOKBACK=150
# 試過 0.3 (baseline) → 0.4 收得更多有效支撐 cluster
MASR_SHORT_RES_TOL_ATR_MULT=0.4
MASR_SHORT_RES_MIN_TOUCHES=2
# v1 用 1.5（過嚴），v2 改 1.2；P12C confirm 1.2 對 fast 仍最佳
MASR_SHORT_VOL_MULT=1.2
# 反追殺保險（v2 用 V2_RSI_MIN / V2_MAX_DIST_FROM_EMA200 較寬鬆值）
MASR_SHORT_RSI_HTF_TIMEFRAME=4h
MASR_SHORT_RSI_PERIOD=14
MASR_SHORT_RSI_MIN=30.0
MASR_SHORT_MAX_DIST_FROM_EMA200=0.10
MASR_SHORT_MAX_24H_DROP_PCT=0.08

# ── 出場 ── P12C sweep 後保守版 ──
# 試過 1.2 (baseline) / 3.0 (raw best)；2.5 = stability-adjusted #1
# wr_std 2.2pp / 三段最均勻
MASR_SHORT_SL_ATR_MULT=2.5
# 試過 2.0 (baseline) → 1.5 早出 TP1 換高 WR（兩 variant 共識）
MASR_SHORT_TP1_RR=1.5
MASR_SHORT_TP2_RR=4.0
MASR_SHORT_BE_AFTER_TP1=true
MASR_SHORT_MIN_SCORE=2
MASR_SHORT_TIMEOUT_BARS=24
MASR_SHORT_MIN_RR=1.5

# MASR Short v2 variant (P12C 後 live 預設)
# 證據: reports/p12c_masr_short_sweep_20260430_2305.md
# 在 sweep 後參數下，fast 顯著優於 slow（adj +124.23 vs +83.58U）
# 注意：P12 baseline 比較時 slow 較好，但那是 baseline config。
# Sweep 找到的最佳 config (LOOKBACK=150 / TOL=0.4 / TP1=1.5 / SL=2.5)
# 下，fast variant stability 全面領先（wr_std 2.2pp vs 4.7pp）。
MASR_SHORT_VARIANT=fast

# === MASR Short v2（分級大盤 + 鬆綁，回測對照用）===
# 強做空：BTC 1D EMA50<EMA200（嚴，正常倉）
# 弱做空：BTC 4H close<EMA50 且 24h<+1%（鬆，半倉）
MASR_SHORT_V2_VARIANT=fast               # fast | slow
MASR_SHORT_V2_WEAK_BTC_24H_MAX=0.01
MASR_SHORT_V2_WEAK_QTY_MULT=0.5
MASR_SHORT_V2_VOL_M=30.0
MASR_SHORT_V2_7D_MAX_RETURN=0.03
MASR_SHORT_V2_DIST_HIGH_PCT=0.08
MASR_SHORT_V2_TOP_N=50
MASR_SHORT_V2_VOL_MULT=1.2
MASR_SHORT_V2_RSI_MIN=35.0
MASR_SHORT_V2_MAX_DIST_FROM_EMA200=0.12
MASR_SHORT_V2_SLOW_OFFSET_ATR=0.2

# === 回測 K 線檔案 cache TTL（秒）===
BT_KLINE_CACHE_TTL_SEC=86400

# === Shadow comparison（live vs backtest 訊號等價性監控，testnet 預設 ON）===
# 訊號產生時觸發 shadow_runner.shadow_compare_signal()，比對 live 訊號跟
# backtest path 在同一 K 線上算出的訊號。real_mismatch (不在 KNOWN_ACCEPTABLE
# _DIFFS 內) → notifier 警報。設 false 關掉（prod 穩定後可關）。
ENABLE_SHADOW_COMPARE=true

# === Feature filters（backtest only，源自 pattern mining）===
# 僅作用於 scripts/backtest.py 的 run_backtest_{masr,bd,smc}；
# live 路徑（bot_main / strategies/*）不讀這層，screener 不受影響。
# Master switch：false 等於整層 filter 關掉，回到原始行為。
BACKTEST_USE_FEATURE_FILTERS=true

# SMC：跳過高 BTC 相關幣
# pattern_miner: low_corr coins +5.54U vs high_corr -2.02U（WR diff 12.9pp）
SMC_BTC_CORR_MAX=0.74

# BD：跳過弱趨勢幣（regime 不對）
# pattern_miner: high_adx coins +12.10U vs low_adx -8.13U（WR diff 12.2pp）
BD_MIN_ADX_MED=28

# MASR：跳過 cfd 類資產（XAU / XAG / CL）
# pattern_miner: crypto_major +27U vs cfd +0.4U
# 逗號分隔；空字串 fallback 至 default ["cfd"]
MASR_EXCLUDE_ASSET_CLASSES=cfd

# ── 抽象化 rule list（P2B-1，覆蓋上面 legacy 單值 env）────────
# 想用組合條件就設這個，JSON list of {feature, op, threshold}
# op 支援：>= <= > < == != in not_in
# <STRATEGY>_REQUIRE_ALL: true=AND、false=OR；預設 true
#
# 範例：
# SMC_RULES_JSON=[{"feature":"btc_corr_30d","op":"<=","threshold":0.74}]
# BD_RULES_JSON=[{"feature":"adx_med","op":">=","threshold":28}]
# MASR_RULES_JSON=[{"feature":"asset_class","op":"not_in","threshold":["cfd"]}]
#
# NKF / MR 預設無 rule（不 filter）；要啟用 backtest filter 才設：
# NKF_RULES_JSON=[]
# NKF_REQUIRE_ALL=true
# MR_RULES_JSON=[]
# MR_REQUIRE_ALL=true

# === Granville 葛蘭碧策略（精簡 4 法則：1, 2, 5, 6）===
GRANVILLE_TIMEFRAME=4h
GRANVILLE_EMA_PERIOD=60
GRANVILLE_BREAKOUT_ATR_MULT=0.3
GRANVILLE_ADX_MIN=20.0
GRANVILLE_VOL_MIN_MULT=1.0
GRANVILLE_RETRACE_ATR_MULT=0.5
GRANVILLE_ADD_SIZE_MULT=0.5
GRANVILLE_SL_ATR_MULT=1.5
GRANVILLE_TP1_ATR_MULT=2.0
GRANVILLE_TP2_ATR_MULT=4.0
GRANVILLE_TRAILING_AFTER_TP1=true
GRANVILLE_MAX_HOLD_BARS=30
GRANVILLE_CONSEC_LOSS_LIMIT=3
GRANVILLE_PAUSE_HOURS=12.0
GRANVILLE_SCREEN_MIN_SCORE=7
GRANVILLE_SCREEN_VOL_M=100.0
GRANVILLE_SCREEN_ATR_MIN_PCT=1.5
GRANVILLE_SCREEN_ATR_MAX_PCT=4.0
GRANVILLE_SCREEN_TOP_N=4
GRANVILLE_MIN_RR=1.3

# === Layer 2：方向中性護欄 ===
DIRECTIONAL_BALANCE_RATIO_MAX=3.0

# === SMC（Smart Money Concepts: Liquidity Sweep + Reversal）===
# 取代 MR：刺破 swing high/low 後反轉時順機構方向開倉
SMC_TIMEFRAME=1h
SMC_SWING_LOOKBACK=50
SMC_SWING_LEFT=3
SMC_SWING_RIGHT=3
SMC_SWEEP_MIN_PCT=0.001    # 0.1%
SMC_SWEEP_MAX_PCT=0.020    # 2%
SMC_VOL_MULT=1.3
SMC_SL_BUFFER=0.5          # SL = 刺破點 + 0.5×ATR
SMC_MIN_SCORE=3
SMC_TIMEOUT_BARS=24        # 1h × 24 = 24h（v2：給 sweep+reversal 足夠時間達 TP）
SMC_MIN_RR=1.5
# v3 HTF 趨勢過濾：4h EMA50 與交易方向同向才開倉
SMC_HTF_FILTER_ENABLED=true
SMC_HTF_TIMEFRAME=4h
SMC_HTF_EMA_PERIOD=50
# v4 嚴 HTF：4h close 離 EMA 至少 0.5%（避免貼 EMA 的 chop）
SMC_HTF_MIN_DISTANCE_PCT=0.005
# v4 個別幣排除（gap risk 高 / 結構性失敗）
SMC_EXCLUDED_SYMBOLS=HYPEUSDT
# v5 EMA 斜率：要求 4h EMA50 過去 N 根朝交易方向移動（真趨勢非反彈）
SMC_HTF_REQUIRE_SLOPE=true
SMC_HTF_SLOPE_BARS=5
# v6 斜率強度：避免「微正斜率」被誤判為真趨勢，要求漲跌幅 ≥ 0.5%
SMC_HTF_MIN_SLOPE_PCT=0.005
# v7 per-coin 自動學習（預設關閉：6 個月回測樣本太小、誤擋 winning streak）
# 等 live 累積 30+ 真實樣本後可開
SMC_AUTO_EXCLUDE_ENABLED=false
SMC_AUTO_EXCLUDE_MIN_TRADES=30
SMC_AUTO_EXCLUDE_WIN_THRESHOLD=0.35
SMC_AUTO_EXCLUDE_LOOKBACK=30

# === BD（Breakdown Short）參數 ===
# 回測：45.4% win, +14.85，提高 MIN_RR 過濾低 RR 訊號
BD_MIN_RR=1.5
# v5：個幣 24h 必須跑輸 BTC ≥ 1% 才開倉（對齊 ML 的 hard rel-strength filter）
BD_REL_STRENGTH_ENABLED=true
BD_REL_STRENGTH_MIN_DIFF=1.0
# v2 結構補強：multi-bar confirm + 拒絕殺底 + 失敗反彈前置
# BD v2 經 12m 回測驗證失敗（v1 -1.26 → v2 -9.99）：multi-bar
# 等確認反而錯過 BD 初期動量。預設全關，保留 env 供未來改進嘗試。
BD_V2_ENABLED=false
BD_V2_REQUIRE_CONFIRM=false
BD_V2_REJECT_NEAR_SUPPORT=false
BD_V2_SUPPORT_LOOKBACK=30
BD_V2_SUPPORT_ATR_MULT=1.0
BD_V2_REQUIRE_LOWER_HIGHS=false
BD_V2_LH_LOOKBACK=30

# === MR（RSI 均值回歸）參數 ===
MR_TIMEFRAME=15m
MR_RSI_PERIOD=14
MR_RSI_OVERSOLD=30
MR_RSI_OVERBOUGHT=70
MR_BB_PERIOD=20
MR_BB_STD=2.0
MR_TP_PCT=0.04            # 4% 止盈（從 6% 降低，避免 TIMEOUT 出場吃手續費）
MR_SL_PCT=0.035           # 3.5% 止損（從 2.5% 放寬：SL 命中率 55%+ 太高被噪音洗）
MR_MIN_SCORE=2
MR_VOL_MULT=0.9
MR_TIMEOUT_BARS=20
MR_MIN_RR=1.2
# v5：結構性過濾（解 MR 邊際負期望）
# - DIVERGENCE：正規 RSI 背離（價格 LL/HH + RSI HL/LH，≥2 點 RSI 差）
# - SR_TEST：當前 close 接近最近 swing low/high（±SR_TOLERANCE）
# MR_STRUCTURAL_REQUIRED：要通過幾道才放行
#   0 = 都不擋（純 RSI/BB 觸發）
#   1 = 至少一道（默認，過濾雜訊保留訊號量）— 兩道都要訊號量幾乎為 0
#   2 = 兩道都要（嚴格）
MR_REQUIRE_DIVERGENCE=true
MR_REQUIRE_SR_TEST=true
MR_STRUCTURAL_REQUIRED=1
MR_DIV_LOOKBACK=20        # 找 RSI 背離回看根數
MR_SR_LOOKBACK=30         # 找 S/R 關鍵位回看根數
MR_SR_TOLERANCE=0.015     # 1.5% 容忍貼合

# === OI 異常過濾 ===
OI_CHANGE_MAX=30          # OI 24h 變動 >30% 視為異常

# === WebSocket（v5 K 線事件驅動）===
WS_SILENCE_RESET_SEC=300  # 超過此秒數無事件則重建連線

# === 進場前 mark price 偏離擋（v4）===
PRE_ENTRY_MAX_MARK_DEVIATION=0.005  # 0.5%

# === 成交後偏離擋（v5）===
MAX_FILL_SLIP=0.015       # 1.5%

# === 新幣過濾天數（v5）===
NEW_COIN_MIN_DAYS=60

# === Dust 自動關閉門檻（v5）===
DUST_CLOSE_NOTIONAL=1.0   # USDT

# === Telegram 通知 ===
TG_BOT_TOKEN=your_bot_token       # 從 @BotFather 取得
TG_CHAT_ID=your_chat_id           # 從 @userinfobot 取得

# === 資料庫 ===
DB_PATH=bot_state.db
