# 幣安 API（只開合約交易，絕對不開提幣）
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here

# 環境設定（true = Testnet，false = 真實交易）
BINANCE_TESTNET=true

# 風控參數
MAX_LEVERAGE=2            # 最大槓桿倍率
RISK_PER_TRADE=0.03       # 每筆最大風險 3%（佔可用餘額）
MAX_POSITIONS=5           # 同時最多開幾個倉
MAX_NOTIONAL_PCT=0.20     # 單筆保證金不超過帳戶 20%

# 排程設定
RESCAN_MIN=15             # 每幾分鐘重新選幣
SIGNAL_CHECK_MIN=5        # 每幾分鐘檢查訊號
SYNC_SEC=30               # 每幾秒同步倉位狀態

# 策略參數
COOLDOWN_BARS=6           # 止損後冷卻 K 棒數
MIN_SIGNAL_SCORE=3        # 最低訊號強度（1-5）

# 資料庫
DB_PATH=bot_state.db
