# 幣安 API（只開合約交易，絕對不開提幣）
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here

# 環境設定（true = Testnet，false = 真實交易）
BINANCE_TESTNET=true

# 風控參數
MAX_LEVERAGE=3            # 固定槓桿（多策略 v5）
RISK_PER_TRADE=0.05       # 每筆最大風險 5%（佔可用餘額）
MAX_POSITIONS=6           # 同時最多開 6 個倉
MAX_NOTIONAL_PCT=0.1667   # 單筆保證金 ≈ 1/6 帳戶，平均分攝
MAX_DAILY_LOSS=0.08       # 每日最大虧損 8%
MAX_SAME_DIR_HIGH_CORR=2  # 同方向高相關倉位上限
HIGH_CORR_THRESHOLD=0.8   # 高相關判定門檻

# 策略 R:R 門檻（per-strategy）
NKF_MIN_RR=1.2            # 裸K+Fib 最小淨 R:R
MR_MIN_RR=1.05            # 均值回歸最小淨 R:R

# 排程設定
RESCAN_MIN=15             # 每幾分鐘重新選幣
SIGNAL_CHECK_MIN=5        # 每幾分鐘檢查訊號
SYNC_SEC=30               # 每幾秒同步倉位狀態

# 策略選擇：naked_k_fib / mean_reversion / all
ACTIVE_STRATEGY=all

# 共通策略參數
COOLDOWN_BARS=6           # 止損後冷卻 K 棒數
MIN_SIGNAL_SCORE=3        # NKF 最低訊號強度（1-5）

# 選幣（NKF）
SCREEN_MIN_SCORE=8
SCREEN_MIN_VOL_M=10       # 百萬 USDT
SCREEN_ADX_MIN=20
SCREEN_ADX_MAX=45
SCREEN_ATR_MAX_LONG=4.0
SCREEN_ATR_MAX_SHORT=8.0

# 均值回歸（MR）參數
MR_TIMEFRAME=15m
MR_RSI_PERIOD=14
MR_RSI_OVERSOLD=20
MR_RSI_OVERBOUGHT=80
MR_BB_PERIOD=20
MR_BB_STD=2.0
MR_TP_PCT=0.05            # 5% 止盈上限
MR_SL_PCT=0.025           # 2.5% 止損上限（實際取 min(此值, 1×ATR)）
MR_MIN_SCORE=3
MR_VOL_MULT=0.8           # MR 縮量確認倍率
MR_TIMEOUT_BARS=20        # 超時 K 棒數

# 資料庫
DB_PATH=bot_state.db
